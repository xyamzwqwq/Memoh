#!/bin/sh
set -eu

TOOLKIT="${MEMOH_TOOLKIT_DIR:-/opt/memoh/toolkit}"
HERMES_AGENT_VERSION="${HERMES_AGENT_VERSION:-0.17.0}"
HERMES_AGENT_PACKAGE="${HERMES_AGENT_PACKAGE:-hermes-agent[acp,mcp]==$HERMES_AGENT_VERSION}"
TOOLKIT_CA_BUNDLE="$TOOLKIT/certs/ca-certificates.crt"
RUNTIME_ROOT="${MEMOH_HERMES_RUNTIME_DIR:-${XDG_CACHE_HOME:-/tmp}/memoh-hermes-acp/$HERMES_AGENT_VERSION}"
SEED_CACHE_DIR="$TOOLKIT/uv-cache"
SEED_TOOL_DIR="$TOOLKIT/uv-tools"
SEED_PYTHON_DIR="$TOOLKIT/python"
SEED_MARKER=".memoh-seeded-v3"

if [ -z "${SSL_CERT_FILE:-}" ] && [ -f "$TOOLKIT_CA_BUNDLE" ]; then
  export SSL_CERT_FILE="$TOOLKIT_CA_BUNDLE"
fi

if [ ! -x "$TOOLKIT/uv" ]; then
  echo "hermes-acp requires uv in the Memoh workspace toolkit: $TOOLKIT/uv" >&2
  exit 127
fi

seed_dir() {
  src="$1"
  dst="$2"
  [ -d "$src" ] || return 0
  if [ -e "$dst/$SEED_MARKER" ]; then
    chmod -R u+rwX "$dst"
    return 0
  fi
  mkdir -p "$dst"
  cp -a "$src"/. "$dst"/
  chmod -R u+rwX "$dst"
  rm -f "$dst/.memoh-seeded"
  : > "$dst/$SEED_MARKER"
}

mkdir -p "$RUNTIME_ROOT"
export UV_CACHE_DIR="${UV_CACHE_DIR:-$RUNTIME_ROOT/uv-cache}"
export UV_TOOL_DIR="${UV_TOOL_DIR:-$RUNTIME_ROOT/uv-tools}"
export UV_PYTHON_INSTALL_DIR="${UV_PYTHON_INSTALL_DIR:-$RUNTIME_ROOT/python}"

seed_dir "$SEED_CACHE_DIR" "$UV_CACHE_DIR"
seed_dir "$SEED_TOOL_DIR" "$UV_TOOL_DIR"
seed_dir "$SEED_PYTHON_DIR" "$UV_PYTHON_INSTALL_DIR"

if [ "${MEMOH_HERMES_ALLOW_NETWORK_INSTALL:-}" = "1" ]; then
  exec "$TOOLKIT/uv" tool run --from "$HERMES_AGENT_PACKAGE" hermes-acp "$@"
fi

exec "$TOOLKIT/uv" tool run --offline --from "$HERMES_AGENT_PACKAGE" hermes-acp "$@"

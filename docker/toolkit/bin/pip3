#!/bin/sh
TOOLKIT="${MEMOH_TOOLKIT_DIR:-/opt/memoh/toolkit}"
TOOLKIT_CA_BUNDLE="$TOOLKIT/certs/ca-certificates.crt"

case "$(uname -m)" in
  x86_64) PYTHON_ARCH=x86_64 ;;
  aarch64|arm64) PYTHON_ARCH=aarch64 ;;
  *) echo "ERROR: unsupported architecture: $(uname -m)" >&2; exit 1 ;;
esac

if ls /lib/ld-musl-*.so.1 >/dev/null 2>&1; then
  PYTHON_LIBC=musl
else
  PYTHON_LIBC=gnu
fi

if [ -z "${SSL_CERT_FILE:-}" ] && [ -f "$TOOLKIT_CA_BUNDLE" ]; then
  export SSL_CERT_FILE="$TOOLKIT_CA_BUNDLE"
fi

for PYTHONDIR in "$TOOLKIT/python-$PYTHON_LIBC-$PYTHON_ARCH" "$TOOLKIT/python-$PYTHON_LIBC"; do
  if [ -x "$PYTHONDIR/bin/pip3" ]; then
    export PATH="$PYTHONDIR/bin:$PATH"
    exec "$PYTHONDIR/bin/pip3" "$@"
  fi
done

echo "pip3 is not installed in the Memoh workspace toolkit for ${PYTHON_LIBC}/${PYTHON_ARCH}" >&2
exit 127
